TELEGRAM_TOKEN=your-telegram-bot-token
SERVICE_API_TOKEN=dev-service-token
JWT_SECRET=replace-with-long-random-secret
SITE_LOGIN_URL=http://localhost:3000/login?token={token}
VITE_API_BASE_URL=http://localhost:8000

# Development: true returns email verification codes in API responses.
# Production: set false and configure SMTP below.
EXPOSE_DEV_EMAIL_CODE=true

# SMTP settings for real email verification codes.
# Example for STARTTLS providers: SMTP_PORT=587, SMTP_USE_SSL=false, SMTP_STARTTLS=true.
# Example for SSL providers: SMTP_PORT=465, SMTP_USE_SSL=true, SMTP_STARTTLS=false.
EMAIL_FROM=no-reply@example.com
EMAIL_FROM_NAME=Parser Monitor
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=false
SMTP_STARTTLS=true
SMTP_TIMEOUT_SECONDS=10
